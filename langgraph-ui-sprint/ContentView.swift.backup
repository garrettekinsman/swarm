import SwiftUI

struct ContentView: View {
    @EnvironmentObject private var nostrService: NostrService
    @EnvironmentObject private var keysManager: KeysManager
    @EnvironmentObject private var messageStore: MessageStore
    
    @State private var columnVisibility: NavigationSplitViewVisibility = .all
    @State private var selectedContactPubkey: String?
    
    var body: some View {
        NavigationSplitView(columnVisibility: $columnVisibility) {
            ContactListView(selectedContactPubkey: $selectedContactPubkey)
        } content: {
            if let pubkey = selectedContactPubkey {
                conversationContent(for: pubkey)
            } else {
                emptyContent
            }
        } detail: {
            emptyDetail
        }
        .navigationSplitViewStyle(.balanced)
    }
    
    private func conversationContent(for pubkey: String) -> some View {
        VStack {
            Text("Conversation with")
                .font(.system(size: 17, weight: .semibold))
                .foregroundStyle(Color(red: 0.961, green: 0.961, blue: 0.969, opacity: 1.0))
            Text(truncatedNpub(pubkey))
                .font(.system(size: 15))
                .foregroundStyle(Color(red: 0.580, green: 0.608, blue: 0.643, opacity: 1.0))
            
            ScrollView {
                LazyVStack(spacing: 8) {
                    ForEach(messageStore.messages(for: pubkey)) { message in
                        VStack(alignment: .leading, spacing: 4) {
                            Text(message.senderPubkey == keysManager.currentKeypair?.publicKey.hex ? "You" : truncatedNpub(message.senderPubkey))
                                .font(.system(size: 13, weight: .semibold))
                                .foregroundStyle(Color(red: 0.580, green: 0.608, blue: 0.643, opacity: 1.0))
                            Text(message.content)
                                .font(.system(size: 15))
                                .foregroundStyle(Color(red: 0.961, green: 0.961, blue: 0.969, opacity: 1.0))
                        }
                        .frame(maxWidth: .infinity, alignment: .leading)
                        .padding(12)
                        .background(Color(red: 0.173, green: 0.173, blue: 0.180, opacity: 1.0))
                        .cornerRadius(8)
                    }
                }
                .padding(16)
            }
        }
        .frame(maxWidth: .infinity, maxHeight: .infinity)
        .background(Color(red: 0.051, green: 0.051, blue: 0.051, opacity: 1.0))
    }
    
    private var emptyContent: some View {
        VStack(spacing: 16) {
            Image(systemName: "bubble.left.and.bubble.right.fill")
                .font(.system(size: 64))
                .foregroundStyle(Color(red: 0.580, green: 0.608, blue: 0.643, opacity: 0.3))
                .symbolRenderingMode(.hierarchical)
            
            Text("Select a conversation")
                .font(.system(size: 20, weight: .semibold))
                .foregroundStyle(Color(red: 0.580, green: 0.608, blue: 0.643, opacity: 1.0))
        }
        .frame(maxWidth: .infinity, maxHeight: .infinity)
        .background(Color(red: 0.051, green: 0.051, blue: 0.051, opacity: 1.0))
    }
    
    private var emptyDetail: some View {
        Color(red: 0.051, green: 0.051, blue: 0.051, opacity: 1.0)
            .ignoresSafeArea()
    }
    
    private func truncatedNpub(_ pubkey: String) -> String {
        guard pubkey.count >= 8 else { return pubkey }
        return "\(pubkey.prefix(6))…\(pubkey.suffix(6))"
    }
}
